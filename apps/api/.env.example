NODE_ENV=development
HOST=0.0.0.0
PORT=3333
CORS_ORIGIN=http://localhost:4200

# AWS RDS PostgreSQL 17. Store the real value in Vercel environment variables.
DATABASE_URL=postgres://postgres:<password>@<rds-endpoint>:5432/hackathon
PGSSLMODE=require
PG_POOL_MAX=5

# Optional OCR for scanned PDFs and images. Text documents work without it.
ANTHROPIC_API_KEY=
ANTHROPIC_OCR_MODEL=claude-sonnet-4-20250514

