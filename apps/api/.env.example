NODE_ENV=development
HOST=0.0.0.0
PORT=3333
CORS_ORIGIN=http://localhost:4200

# AWS RDS PostgreSQL 17. Store the real value in Vercel environment variables.
DATABASE_URL=postgres://postgres:<password>@<rds-endpoint>:5432/hackathon
PGSSLMODE=require
PG_POOL_MAX=5

# AWS Bedrock LLM. Set credentials only in an ignored local .env or Vercel secrets.
BEDROCK_CONTEXT_MAX_CHARS=12000
LLM_PROVIDER=bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
BEDROCK_OCR_MODEL_ID=us.anthropic.claude-sonnet-4-6
BEDROCK_LIGHTWEIGHT_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_EMBEDDING_MODEL_ID=cohere.embed-english-v3
