NODE_ENV=development
HOST=0.0.0.0
PORT=3333
CORS_ORIGIN=http://localhost:4200

# Neon PostgreSQL. Use the pooled connection string for Vercel Functions and
# store the real value only in Vercel environment variables.
DATABASE_URL=postgresql://<role>:<password>@<endpoint>-pooler.<region>.aws.neon.tech/<database>?sslmode=require
PGSSLMODE=require
PG_POOL_MAX=5

# Optional OCR for scanned PDFs and images. Text documents work without it.
ANTHROPIC_API_KEY=
ANTHROPIC_OCR_MODEL=claude-sonnet-4-20250514

# AWS Bedrock LLM. Set credentials only in an ignored local .env or Vercel secrets.
BEDROCK_CONTEXT_MAX_CHARS=12000
LLM_PROVIDER=bedrock
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
BEDROCK_LIGHTWEIGHT_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_EMBEDDING_MODEL_ID=cohere.embed-english-v3
